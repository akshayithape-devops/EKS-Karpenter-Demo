# Local .terraform directory containing provider binaries and modules
.terraform/

# .tfstate files contain sensitive infrastructure data and should NOT be committed
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all variable files as they often contain secrets
*.tfvars
*.tfvars.json

# Exclude override files (used for local modifications)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for specific environments if desired (comment out if not needed)
# !example_override.tf

# Terraform CLI configuration files
.terraformrc
terraform.rc
